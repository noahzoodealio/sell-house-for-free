# sell-house-for-free — environment template
#
# Copy to `.env.local` and fill in real values. The canonical pull from
# Vercel is:
#
#   vercel env pull .env.local --environment=development --yes
#
# All enrichment vars are SERVER-ONLY (no browser-facing prefix). They
# stay out of the browser bundle.

# ─── Property enrichment (E4) ────────────────────────────────────────

# Base URL for the Zoodealio MLS service (required in prod/preview).
MLS_API_BASE_URL=

# HMAC-SHA256 secret the MLS API expects in `Jwt:SecretKey`. When set, the
# Next.js server mints a short-lived bearer token per-call (mirrors
# Zoodealio.MLS JwtTokenService). Required for the JWT-protected routes
# (/api/properties/search, /api/properties/attom/{id}) — images is anonymous.
# Source: the MLS service's `Jwt:SecretKey` App Service config. Server-only.
MLS_JWT_SECRET=

# Optional override: paste a pre-minted bearer token to skip server-side
# minting. Takes precedence over MLS_JWT_SECRET when set. Intended for
# short-term debugging only — expires on the MLS-side lifetime (prod: 1 day).
MLS_API_TOKEN=

# Timeout (ms) for each MLS HTTP call. Defaults to 4000 when unset.
ENRICHMENT_TIMEOUT_MS=4000

# `unstable_cache` TTL (seconds) for successful enrichment responses.
# Defaults to 86400 (24h). The `no-match` branch uses a shorter 1h TTL
# internally and ignores this var.
ENRICHMENT_CACHE_TTL_SECONDS=86400

# When `true`, `/api/enrich` returns canned fixture responses instead of
# calling the real MLS. Magic `street1` triggers: `__TIMEOUT__`,
# `__NOMATCH__`, `__OUTAREA__`, `__ERROR__`, `__LISTED__`. Defaults to
# `false`. Used by Playwright (E4-S9) and local dev without MLS access.
ENRICHMENT_DEV_MOCK=false

# Base URL for ATTOM's Property Data API (required in prod/preview).
# Canonical value: https://api.gateway.attomdata.com/propertyapi/v1.0.0
ATTOM_API_BASE_URL=

# ATTOM private token — sent as the `apikey` header on every request.
# Shared with ZIP and Offervana; rotate in the ATTOM console when needed.
ATTOM_PRIVATE_TOKEN=

# Comma-separated allow-list of enrichment sources. Default is "mls,attom".
# Set to "mls" to disable ATTOM cheaply in preview deployments or during an
# ATTOM outage — no ATTOM fetch fires. Unknown values fall back to default.
ENRICHMENT_SOURCES=mls,attom

# ─── AI Agent Suite (E9) ─────────────────────────────────────────────

# Vercel AI Gateway credential. SECRET. Every model call routes through the
# gateway; no direct-provider SDK is imported. Obtain from the Vercel
# dashboard: Project → Settings → AI Gateway. Rotate via the dashboard.
AI_GATEWAY_API_KEY=

# Optional override for the AI Gateway base URL. Leave empty to use the
# AI SDK default. Intended for debugging / isolated environments only.
AI_GATEWAY_BASE_URL=

# Optional: transparent failover model (e.g. "openai/gpt-5") when the
# primary provider is unavailable. When unset, requests fail on the
# primary provider's outage. Revisit post-launch after two weeks of
# real traffic.
AI_FALLBACK_MODEL=

# Vercel Workflow DevKit (WDK) queue credential. SECRET. Required when
# the `comp-run` workflow ships (E9-S16). Issued by the `vercel` CLI
# when workflows are enabled for the project.
AI_WORKFLOW_QUEUE_KEY=

# Salt for hashing client IPs into `ai_sessions.ip_hash`. SECRET. Rotating
# invalidates dedup of prior sessions but does not leak past values (sha256
# is one-way). When unset, ip_hash is recorded as null and a single
# startup warning logs.
AI_IP_HASH_SALT=

# Optional: override the 24-message window used by the session compaction
# edge. The story's architecture §3.1.4 defaults to 24 when unset.
AI_SESSION_MESSAGE_WINDOW=24

# Optional: override the default 30-day max session age. Sessions older
# than this are treated as expired (loadSession returns null), matching
# the transcript retention window in docs/ai-agent-policy.md (S7).
AI_SESSION_MAX_AGE_DAYS=30

# Sliding-window rate limit (E9-S4). Counts requests per hashed client IP.
# Defaults are 30 requests per 60 seconds. Exceeding the ceiling returns
# 429 with a friendly message. Counter lives in public.ai_ip_budgets.
AI_IP_WINDOW_SECONDS=60
AI_IP_REQUESTS_PER_WINDOW=30

# ─── Supabase (E5 BFF + E6 PM Service + E9 AI + E10 Auth) ────────────
#
# Shared Supabase project used by E5 idempotency tables, E6 PM service
# (team_members / profiles / submissions / submission_offers /
# assignment_events / notification_log + assign_next_pm RPC), E9 AI
# agent suite, and E10 passwordless auth. Region: us-west-2.
#
# All access is server-only via src/lib/supabase/server.ts. Service-role
# key bypasses RLS; anon key is for future seller-facing client calls
# (E10). Never expose SUPABASE_SERVICE_ROLE_KEY to the browser.

# Supabase project URL. Example: https://abcd1234.supabase.co
SUPABASE_URL=

# Service-role key. SECRET. Bypasses RLS — treat like root database
# credentials. Rotate via Supabase dashboard → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# Anon key (public). Used by future seller-facing client code (E10
# magic-link / OTP flows). Safe to expose to the browser.
SUPABASE_ANON_KEY=

# Browser-safe Supabase URL + anon key (E10). Same values as SUPABASE_URL
# and SUPABASE_ANON_KEY above — the NEXT_PUBLIC_ prefix exposes them to
# the browser bundle for `@supabase/ssr` + the future OTP/magic-link flows.
# RLS (E10-S4) enforces authorization — the anon key alone grants no
# privileged access. The service-role key MUST NEVER gain a NEXT_PUBLIC_
# counterpart.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Email / Resend (E6 PM notification + confirmation) ──────────────
#
# Resend + React Email power the seller confirmation + team-member
# notification sends that fire after a successful E5 submission.
# Templates live in src/lib/email/templates/*.tsx (versioned with code —
# no SendGrid web UI).

# Resend API key. SECRET. Obtain from resend.com → API Keys. Scope to
# "Send only" in production. Rotate via dashboard.
RESEND_API_KEY=

# From address for outbound mail. Must match a domain verified in Resend
# with DKIM + DMARC green. Example: hello@sellyourhousefree.com
EMAIL_FROM=

# Reply-to address for seller replies. Routed to ops inbox. Used by the
# E6 confirmation emails only — team ↔ seller threads (E11-S5) use the
# per-submission `reply-<submission_id>@<RESEND_INBOUND_DOMAIN>` address
# so inbound replies route to the correct submission thread.
EMAIL_REPLY_TO=

# ─── Team-portal messaging (E11-S5) ──────────────────────────────────

# HMAC secret Resend signs the inbound parse webhook with. SHA-256 of
# the raw body, hex-encoded, prefixed `sha256=` in the header
# `X-Resend-Signature`. Configure in Resend dashboard → Webhooks →
# Inbound. Required in production. Rotate by minting a new secret in
# Resend, deploying, then revoking the old one.
RESEND_INBOUND_WEBHOOK_SECRET=

# HMAC secret for Resend delivery-event webhooks (delivered / bounced /
# complained). Same scheme as inbound. Configure in Resend dashboard →
# Webhooks → Sending Events.
RESEND_DELIVERY_WEBHOOK_SECRET=

# Mail subdomain for per-submission reply addresses. Used to mint
# `reply-<submission_id>@<this-domain>` as the Reply-To on outbound
# team → seller messages. DNS must have the Resend-assigned MX records
# pointing inbound at Resend. Defaults to mail.sellfree.xyz when unset.
RESEND_INBOUND_DOMAIN=mail.sellfree.xyz

# Bearer secret for Vercel-scheduled cron jobs (E11-S10
# /api/cron/team-portal/*). Vercel sends `Authorization: Bearer
# ${CRON_SECRET}` automatically when triggering scheduled functions; set
# the same value here in `vercel env` for prod/preview/dev. Manual cURL
# invocations need the same header. Rotate by minting a new secret in
# Vercel + redeploying.
CRON_SECRET=

# Absolute URL of the team portal — used in outbound team-to-seller
# emails as the link to the seller's portal thread. When unset, falls
# back to NEXT_PUBLIC_SITE_URL, then http://localhost:3000.
TEAM_PORTAL_URL=

# Optional: override the "we'll reach out within N hours" commitment in
# confirmation copy (seller email + /portal/setup render). Defaults to
# 24 when unset. Must match copy in src/lib/pm-service/config.ts.
EMAIL_CONTACT_WINDOW_HOURS=24

# Optional: override the assign_next_pm RPC timeout (milliseconds).
# Defaults to 5000 when unset. Short enough that a slow DB doesn't
# block the seller's redirect to /portal/setup.
PM_ASSIGN_TIMEOUT_MS=5000
